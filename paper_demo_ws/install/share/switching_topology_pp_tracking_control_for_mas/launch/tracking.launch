<launch>

  <!-- 机械臂1控制器 -->
  <node pkg="switching_topology_pp_tracking_control_for_mas"
        type="switching_topology_pp_tracking_control_for_mas_tracking_els1"
        name="switching_topology_pp_tracking_control_for_mas_tracking_els1"
        output="screen"
        required="true"/>

  <!-- 机械臂2控制器 -->
  <node pkg="switching_topology_pp_tracking_control_for_mas"
        type="switching_topology_pp_tracking_control_for_mas_tracking_els2"
        name="switching_topology_pp_tracking_control_for_mas_tracking_els2"
        output="screen"
        required="true"/>

  <!-- 机械臂3控制器 -->
  <node pkg="switching_topology_pp_tracking_control_for_mas"
        type="switching_topology_pp_tracking_control_for_mas_tracking_els3"
        name="switching_topology_pp_tracking_control_for_mas_tracking_els3"
        output="screen"
        required="true"/>

  <!-- 机械臂4控制器 -->
  <node pkg="switching_topology_pp_tracking_control_for_mas"
        type="switching_topology_pp_tracking_control_for_mas_tracking_els4"
        name="switching_topology_pp_tracking_control_for_mas_tracking_els4"
        output="screen"
        required="true"/>
        
  <!-- 切换拓扑 -->
  <node pkg="switching_topology_pp_tracking_control_for_mas"
        type="switching_topology_pp_tracking_control_for_mas_tracking_visual"
        name="switching_topology_pp_tracking_control_for_mas_tracking_visual"
        output="screen"
        required="true"/>

</launch>
